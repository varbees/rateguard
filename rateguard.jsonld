{
  "@context": {
    "rateguard": "https://github.com/varbees/rateguard#",
    "AdmissionDecision": "rateguard:AdmissionDecision",
    "TokenBudgetDecision": "rateguard:TokenBudgetDecision",
    "CircuitBreakerDecision": "rateguard:CircuitBreakerDecision",
    "GuardrailViolation": "rateguard:GuardrailViolation",
    "GenAICall": "rateguard:GenAICall",
    "ProviderEntry": "rateguard:ProviderEntry",
    "allowed": {"@type": "xsd:boolean"},
    "applied": {"@type": "xsd:boolean"},
    "remaining": {"@type": "xsd:integer"},
    "retryAfter": {"@type": "xsd:duration"},
    "limit": {"@type": "xsd:integer"},
    "queued": {"@type": "xsd:boolean"},
    "window": {"@type": "xsd:string"},
    "state": {"@type": "xsd:string", "@id": "rateguard:circuitBreakerState"},
    "code": {"@type": "xsd:string", "@id": "rateguard:violationCode"},
    "message": {"@type": "xsd:string"},
    "score": {"@type": "xsd:float"},
    "model": {"@type": "xsd:string", "@id": "rateguard:modelId"},
    "provider": {"@type": "xsd:string", "@id": "rateguard:providerName"},
    "operation": {"@type": "xsd:string", "@id": "rateguard:genaiOperation"},
    "promptTokens": {"@type": "xsd:integer", "@id": "gen_ai:usage.input_tokens"},
    "completionTokens": {"@type": "xsd:integer", "@id": "gen_ai:usage.output_tokens"},
    "totalTokens": {"@type": "xsd:integer", "@id": "rateguard:usage.total_tokens"},
    "estimatedCostUSD": {"@type": "xsd:float", "@id": "rateguard:usage.cost_usd"},
    "streaming": {"@type": "xsd:boolean"},
    "streamChunks": {"@type": "xsd:integer"},
    "timeToFirstChunkMs": {"@type": "xsd:integer", "@id": "gen_ai:operation.time_to_first_chunk"},
    "timePerOutputChunkMs": {"@type": "xsd:float", "@id": "gen_ai:operation.time_per_output_chunk"},
    "conversationId": {"@type": "xsd:string", "@id": "gen_ai:conversation.id"},
    "responseId": {"@type": "xsd:string", "@id": "gen_ai:response.id"},
    "rateLimitApplied": {"@type": "xsd:boolean"},
    "tokenBudgetApplied": {"@type": "xsd:boolean"},
    "tokenBudgetRemaining": {"@type": "xsd:integer"},
    "circuitBreakerState": {"@type": "xsd:string"},
    "name": {"@type": "xsd:string"},
    "baseURL": {"@type": "xsd:anyURI"},
    "headers": {"@type": "@json"},
    "weight": {"@type": "xsd:integer"}
  },
  "rateguard:presets": {
    "dev": {"rps": 10, "burst": 20, "tokensPerHour": 1000, "tokensPerDay": 10000, "tokensPerMonth": 100000, "mode": "hard-stop"},
    "standard": {"rps": 100, "burst": 200, "tokensPerHour": 10000, "tokensPerDay": 100000, "tokensPerMonth": 1000000, "mode": "hard-stop"},
    "high-throughput": {"rps": 1000, "burst": 2000, "tokensPerHour": 100000, "tokensPerDay": 1000000, "tokensPerMonth": 10000000, "mode": "hard-stop"},
    "streaming-llm": {"rps": 200, "burst": 500, "tokensPerHour": 500000, "tokensPerDay": 5000000, "tokensPerMonth": 500000000, "mode": "soft-stop"},
    "agent-orchestrator": {"rps": 500, "burst": 1000, "tokensPerHour": 1000000, "tokensPerDay": 10000000, "tokensPerMonth": 1000000000, "mode": "soft-stop"},
    "llm-heavy": {"rps": 500, "burst": 1000, "tokensPerHour": 250000, "tokensPerDay": 2500000, "tokensPerMonth": 250000000, "mode": "soft-stop"},
    "mcp-server": {"rps": 30, "burst": 60, "tokensPerHour": 50000, "tokensPerDay": 500000, "tokensPerMonth": 50000000, "mode": "hard-stop"},
    "strict-upstream-protection": {"rps": 50, "burst": 75, "tokensPerHour": 5000, "tokensPerDay": 20000, "tokensPerMonth": 2000000, "mode": "hard-stop"}
  },
  "rateguard:algorithms": {
    "tokenBucket": {
      "formula": "tokens = min(burst, tokens + elapsed * rps)",
      "allowCondition": "tokens >= 1.0",
      "denyRetryAfter": "ceil((1.0 - tokens) / rps) * 1000ms",
      "source": "https://en.wikipedia.org/wiki/Token_bucket"
    },
    "loopDetection": {
      "fingerprint": "SHA256(system_prompt + user_input + tool_definitions)",
      "haltCondition": "same fingerprint at higher sequence depth, or depth > maxDepth (default 50)",
      "state": "LRU-bounded (10K fingerprints)"
    }
  },
  "rateguard:mcpTools": {
    "transport": "stdio JSON-RPC 2.0 (Go: SDK.ServeMCP), tool factories in Node/Python",
    "semantics": "peek — pre-flight queries never consume budget",
    "tools": ["get_rate_limit_state", "get_token_budget", "get_circuit_breaker_state", "check_loop", "list_limits"]
  },
  "rateguard:modelPricing": {
    "gpt-4o": {"promptPer1K": 0.0025, "completionPer1K": 0.010},
    "gpt-4o-mini": {"promptPer1K": 0.00015, "completionPer1K": 0.0006},
    "gpt-4.1": {"promptPer1K": 0.002, "completionPer1K": 0.008},
    "gpt-4.1-mini": {"promptPer1K": 0.0001, "completionPer1K": 0.0004},
    "o3": {"promptPer1K": 0.002, "completionPer1K": 0.008},
    "o4-mini": {"promptPer1K": 0.0011, "completionPer1K": 0.0044},
    "claude-opus-4-5": {"promptPer1K": 0.005, "completionPer1K": 0.025},
    "claude-sonnet-4": {"promptPer1K": 0.003, "completionPer1K": 0.015},
    "claude-haiku-3.5": {"promptPer1K": 0.0008, "completionPer1K": 0.004},
    "gemini-2.5-pro": {"promptPer1K": 0.00125, "completionPer1K": 0.010},
    "gemini-2.5-flash": {"promptPer1K": 0.000075, "completionPer1K": 0.0003},
    "llama-3.3-70b": {"promptPer1K": 0.00059, "completionPer1K": 0.00079},
    "deepseek-v3": {"promptPer1K": 0.00027, "completionPer1K": 0.0011},
    "deepseek-r1": {"promptPer1K": 0.00055, "completionPer1K": 0.00219}
  }
}
