# Copy this file to deploy/docker/.env to customize local or staging runs.

# Core service ports
POSTGRES_PORT=5432
REDIS_PORT_HOST=6379
GRAFANA_PORT=3300

# API / websocket endpoints seen by the browser
NEXT_PUBLIC_API_URL=http://localhost:8008
NEXT_PUBLIC_WS_URL=ws://localhost:8008

# Browser origin allowlists for local and staging runs
# Include the dashboard port you actually use (`task ui:dev` uses 3003)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3003
WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3003

# Internal URL used by Next.js rewrites inside the dashboard container
RATEGUARD_INTERNAL_API_URL=http://gateway:8008

# Gateway runtime
BASE_URL=http://localhost:8008
AGG_SERVER_HOST=0.0.0.0
AGG_SERVER_PORT=8008
AGG_SERVER_READ_TIMEOUT_SEC=30
AGG_SERVER_WRITE_TIMEOUT_SEC=30
AGG_SERVER_SHUTDOWN_TIMEOUT_SEC=30
AGG_WORKER_POOL_WORKER_COUNT=20
AGG_WORKER_POOL_QUEUE_SIZE=200
AGG_RATE_LIMITER_REQUESTS_PER_SECOND=100
AGG_RATE_LIMITER_BURST_SIZE=200
AGG_RATE_LIMITER_ENABLED=true
AGG_LOGGING_LEVEL=info
AGG_LOGGING_FORMAT=console
AGG_LOGGING_DEVELOPMENT=true
AGG_TIMEOUTS_API_REQUEST_SEC=10
AGG_TIMEOUTS_AGGREGATION_SEC=60
AGG_TIMEOUTS_HTTP_CLIENT_SEC=30
AGG_TIMEOUTS_IDLE_CONN_SEC=90
AGG_RATEGUARD_ENABLE_MULTI_LIMITER=true
AGG_RATEGUARD_CLEANUP_INTERVAL_MIN=60
AGG_RATEGUARD_RATELIMIT_BACKEND=redis
AGG_RATEGUARD_CIRCUIT_BREAKER_MAX_FAILURES=5
AGG_RATEGUARD_CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
AGG_RATEGUARD_CIRCUIT_BREAKER_MAX_CONCURRENT_REQUESTS_HALF_OPEN=1
AGG_RATEGUARD_CIRCUIT_BREAKER_SUCCESS_THRESHOLD_HALF_OPEN=2
AGG_WEBHOOK_ENABLED=true
AGG_WEBHOOK_WORKER_COUNT=5
AGG_WEBHOOK_POLL_INTERVAL_SEC=5
AGG_WEBHOOK_DELIVERY_TIMEOUT_SEC=30
AGG_WEBHOOK_MAX_RETRIES=5
AGG_WEBHOOK_BASE_RETRY_DELAY_SEC=5
AGG_WEBHOOK_MAX_RETRY_DELAY_SEC=300
AGG_WEBHOOK_RETENTION_DAYS=30
OTEL_SERVICE_NAME=rateguard-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
JWT_SECRET=dev-jwt-secret
ENCRYPTION_KEY=dev-encryption-key

# Postgres
POSTGRES_USER=rateguard
POSTGRES_PASSWORD=rateguard_dev_pass
POSTGRES_DB=rateguard

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Optional OSS commercial envs remain blank in the default stack
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
