{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rateguard",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "rateguard.antharmaya.com", "custom_domain": true }
  ]
}
