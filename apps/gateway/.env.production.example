# RateGuard Production Configuration

# Server Configuration
SERVER_PORT=8008
BASE_URL=https://api.rateguard.yourdomain.com

# Database Configuration (PostgreSQL)
DB_HOST=your-postgres-host.com
DB_PORT=5432
DB_USER=rateguard
DB_PASSWORD=your_production_password_here
DB_NAME=rateguard
DB_SSL_MODE=require  # Always require SSL in production

# Authentication
# IMPORTANT: Generate a secure admin API key and keep it secret!
# Generate with: openssl rand -hex 32
API_KEY_ADMIN=your_production_admin_api_key_here

# Worker Pool Configuration
AGG_WORKER_POOL_WORKER_COUNT=50
AGG_WORKER_POOL_QUEUE_SIZE=500

# Rate Limiter Configuration
AGG_RATE_LIMITER_REQUESTS_PER_SECOND=1000
AGG_RATE_LIMITER_BURST_SIZE=2000
AGG_RATE_LIMITER_ENABLED=true

# Logging Configuration
AGG_LOGGING_LEVEL=info
AGG_LOGGING_FORMAT=json  # Use JSON for production logging
AGG_LOGGING_DEVELOPMENT=false

# Timeout Configuration
AGG_TIMEOUTS_API_REQUEST_SEC=30
AGG_TIMEOUTS_AGGREGATION_SEC=60
AGG_TIMEOUTS_HTTP_CLIENT_SEC=30
AGG_TIMEOUTS_IDLE_CONN_SEC=90
