# RateGuard Service Monitoring - Crontab Example
# Add these lines to your crontab with: crontab -e

# Set environment variables (adjust paths and values)
AGG_SERVICE_URL=http://localhost:8008
AGG_WARNING_THRESHOLD=80
AGG_CRITICAL_THRESHOLD=75
# AGG_ALERT_EMAIL=ops@example.com
# AGG_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Check health every 5 minutes
*/5 * * * * /path/to/rateguard/monitoring/check-health.sh >> /var/log/rateguard/health.log 2>&1

# Check stats every 15 minutes
*/15 * * * * /path/to/rateguard/monitoring/check-stats.sh >> /var/log/rateguard/stats.log 2>&1

# Optional: Daily stats summary at 9 AM
0 9 * * * curl -s http://localhost:8008/api/v1/stats | jq '.' | mail -s "Daily RateGuard Stats" ops@example.com
