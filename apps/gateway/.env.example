# RateGuard Gateway - Environment Configuration Example
# Copy this file to .env for manual local runs with `go run ./cmd/main.go`

# Server
AGG_SERVER_HOST=0.0.0.0
AGG_SERVER_PORT=8008

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=rateguard
DB_PASSWORD=rateguard_dev_pass
DB_NAME=rateguard
DB_SSL_MODE=disable

# Redis-backed policy/runtime features
RATE_LIMITER_BACKEND=redis

# Dashboard/browser origins
# Keep this aligned with the dashboard port you actually run.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3003
WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3003

# Authentication and crypto
JWT_SECRET=dev-jwt-secret
ENCRYPTION_KEY=dev-encryption-key

# Observability
OTEL_SERVICE_NAME=rateguard-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Optional billing envs stay blank in OSS-default runs
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
